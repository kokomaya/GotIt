# GotIt Configuration
# Copy this file to .env and fill in your values.

# --- LLM ---
GOTIT_LLM__PROVIDER=claude          # claude | ollama
GOTIT_LLM__API_KEY=sk-ant-...       # Anthropic API key (required for claude)
GOTIT_LLM__MODEL=claude-sonnet-4-6
# GOTIT_LLM__BASE_URL=              # Custom API base URL (optional)

# --- STT ---
GOTIT_STT__ENGINE=whisper_cpp       # whisper_cpp | windows
GOTIT_STT__MODEL_PATH=models/ggml-base.bin
GOTIT_STT__LANGUAGE=zh

# --- Search ---
GOTIT_SEARCH__EVERYTHING_PATH=es.exe
GOTIT_SEARCH__MAX_RESULTS=20

# --- Audio ---
# GOTIT_AUDIO__DEVICE_INDEX=        # Leave empty for default device
GOTIT_AUDIO__SAMPLE_RATE=16000

# --- UI ---
GOTIT_UI__AUTO_CLOSE_DELAY=3        # Main Panel auto-close seconds
GOTIT_UI__GLOBAL_HOTKEY=Ctrl+Shift+G

# --- Server ---
GOTIT_SERVER__HOST=127.0.0.1
GOTIT_SERVER__PORT=8765

# --- Debug ---
GOTIT_DEBUG=false
